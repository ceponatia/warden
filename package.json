{
  "name": "warden",
  "version": "0.1.0",
  "private": true,
  "description": "Tool (CLI, web dash, VS Code extension) for repository health monitoring and reporting across growth, staleness, complexity, and architectural drift.",
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "bin": {
    "warden": "./src/cli/index.ts"
  },
  "scripts": {
    "warden": "tsx src/cli/index.ts",
    "typecheck": "pnpm run typecheck:root && pnpm --filter warden-vscode run typecheck && pnpm --filter @aspect/warden-connector run typecheck && echo \"typecheck OK\"",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.21.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@octokit/rest": "^22.0.0",
    "@types/vscode": "^1.109.0",
    "express": "^5.2.1",
    "marked": "^17.0.3",
    "nodemailer": "^8.0.1",
    "sanitize-html": "^2.17.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}