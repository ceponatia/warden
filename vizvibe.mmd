flowchart TD
    %% === PROJECT GOALS ===
    %% Ultimate Goal: Implement a robust, event-driven trajectory management system within Warden for multi-agent orchestration.

    %% === START ===
    %% @project_start [start, closed]
    project_start("Project Start<br/><sub>Merge Viz Vibe trajectory vibe<br/>into Warden's data-driven architecture</sub>")

    %% @ultimate_goal [end, opened]
    ultimate_goal("Trajectory Orchestration<br/><sub>Full autonomous agent<br/>coordination via Warden state</sub>")

    %% === COMPLETED WORK ===
    %% @layer_0 [task, closed]
    layer_0("Layer 0: Quality Gates<br/><sub>Vitest, CI/CD with frozen lockfile,<br/>and TS global types configured</sub>")

    %% @layer_1 [task, closed]
    layer_1("Layer 1: Canonical Domain<br/><sub>Zod schemas for Graph/Nodes/Edges,<br/>TrajectoryStore with event logging</sub>")

