    layer_3("Layer 3: Product Surfaces<br/><sub>MCP Resources/Tools and<br/>Dashboard visual trajectory view</sub>")

    %% @layer_4 [task, closed]
    layer_4("Layer 4: Safety & Policy<br/><sub>Atomic Patch API, Cycle Detection,<br/>and Optimistic Concurrency</sub>")

