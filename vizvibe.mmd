    hardening("Domain Hardening<br/><sub>Fixed NaN handling, path resolution,<br/>and flaky roundtrip tests</sub>")

    %% === FUTURE WORK ===
    %% @layer_6 [task, opened]
    layer_6("Layer 6: Trajectory Analytics<br/><sub>Predictive work-velocity and<br/>drift detection across repositories</sub>")

