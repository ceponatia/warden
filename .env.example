# AI provider for warden analyze
# Options: openai | anthropic
WARDEN_AI_PROVIDER=openai

# Model override (optional — defaults to gpt-4o for openai, claude-3-5-sonnet-20241022 for anthropic)
# WARDEN_AI_MODEL=gpt-4o

# Required when WARDEN_AI_PROVIDER=openai
OPENAI_API_KEY=

# Required when WARDEN_AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Base URL for the Warden dashboard (used to construct links in notifications)
# Defaults to http://localhost:3333 — override when the dashboard is hosted remotely or on a non-default port
# WARDEN_DASHBOARD_BASE_URL=http://localhost:3333
